# Copy to .env and fill in your keys.
# Only the variables relevant to your chosen provider/storage are required.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: claude | openai | bedrock | azure-openai | mock
LLM_PROVIDER=claude

# Optional model override
# claude default  : claude-haiku-4-5-20251001
# openai default  : gpt-4o-mini
# bedrock default : anthropic.claude-haiku-4-5-20251001-v1:0
# azure-openai    : set to your Azure deployment name (required)
# LLM_MODEL=claude-sonnet-4-6

# ── Direct API Keys (claude / openai) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ── AWS Bedrock (provider=bedrock) ──────────────────────────────────────────
# Alternatively: use an IAM role — boto3 resolves credentials automatically.
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# ── Azure OpenAI (provider=azure-openai) ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name   # set LLM_MODEL to this value

# ── Real Target Chatbot ──────────────────────────────────────────────────────
# Leave blank to use --target mock
# TARGET_CHATBOT_URL=https://your-enterprise-chatbot-api/chat
# TARGET_CHATBOT_API_KEY=your_chatbot_key_here

# ── Experiment Config ────────────────────────────────────────────────────────
# Options: toxicity | prompt-injection | data-leakage | hallucination | persona-hijack | tool-safety
# EVAL_SCENARIO_TYPE=toxicity
# EVAL_BUDGET=100000

# ── MLflow Observability (optional) ─────────────────────────────────────────
# Set to enable experiment tracking. Use a local server (mlflow ui) or remote.
# Leave blank to disable — the harness runs identically without it.
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# ── Result Storage ───────────────────────────────────────────────────────────
# Options: local (default) | s3 | azure-blob

# S3 (--storage s3)
# AWS credentials above are reused by S3 storage.
# S3_BUCKET=your-bucket-name
# S3_PREFIX=adversarial-eval
# S3_REGION=us-east-1

# Azure Blob Storage (--storage azure-blob)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER=results
# AZURE_BLOB_PREFIX=adversarial-eval
