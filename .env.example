# Copy to .env and fill in your keys.
# Only the variables relevant to your chosen tool and provider are required.

# =============================================================================
# LLM Providers (shared by both tools)
# =============================================================================

ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# =============================================================================
# Adversarial Eval — LLM harness provider
# =============================================================================
# Options: claude | openai | bedrock | azure-openai | mock
LLM_PROVIDER=claude

# Optional model override
# claude default  : claude-haiku-4-5-20251001
# openai default  : gpt-4o-mini
# bedrock default : anthropic.claude-haiku-4-5-20251001-v1:0
# azure-openai    : set to your Azure deployment name (required)
# LLM_MODEL=claude-sonnet-4-6

# AWS Bedrock (adversarial eval only)
# Alternatively: use an IAM role — boto3 resolves credentials automatically.
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# Adversarial experiment defaults
# EVAL_SCENARIO_TYPE=toxicity
# EVAL_BUDGET=100000

# MLflow observability (adversarial eval, optional)
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Result storage (adversarial eval, optional — default: local)
# S3_BUCKET=your-bucket-name
# S3_PREFIX=adversarial-eval
# S3_REGION=us-east-1
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_BLOB_CONTAINER=results
# AZURE_BLOB_PREFIX=adversarial-eval

# =============================================================================
# Azure OpenAI (used by both tools)
# =============================================================================
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name
# Optional for synth eval managed identity auth:
# AZURE_AUTH_TYPE=managed_identity
# AZURE_CLIENT_ID=your_managed_identity_client_id
# AZURE_OPENAI_SCOPE=https://cognitiveservices.azure.com/.default

# =============================================================================
# Target Chatbot (used by both tools)
# =============================================================================
# CHATBOT_ENDPOINT=https://your-chatbot-api/chat
# CHATBOT_API_TOKEN=your_api_token_here
# CHATBOT_TIMEOUT=60
# CHATBOT_MODEL=gpt-4.1
# CHATBOT_TEMPERATURE=0.01
# CHATBOT_SOURCE_DOCUMENT_REFERENCE=true

# =============================================================================
# Synth Eval — user simulation LLM
# =============================================================================
# The system auto-detects which provider to use based on available env vars above.
# Optional Ollama (local models):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=glm-4.7-flash:latest

# MODEL_NAME=claude-sonnet-4-5-20250929   # override for synth eval user simulation

# =============================================================================
# Rate limiting & retry (synth eval — applies to user simulation LLM calls)
# =============================================================================
# LOG_LEVEL=INFO
# MODEL_TPM=500000
# MODEL_RPM=500
# MODEL_MAX_RETRIES=2
# MODEL_INITIAL_BACKOFF=0.5
# MODEL_MAX_BACKOFF=10.0
# MODEL_BACKOFF_MULTIPLIER=1.5
# MODEL_RETRY_JITTER=true

# =============================================================================
# SSL (synth eval — for corporate proxies / TLS interception)
# =============================================================================
# VERIFY_SSL=false
# SSL_CERT_FILE=/path/to/corporate-ca-bundle.pem
