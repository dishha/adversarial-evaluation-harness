# Copy to .env and fill in your keys

# LLM provider for harness components (claude or openai)
LLM_PROVIDER=claude

# Optional model override (defaults: claude-haiku-4-5-20251001 / gpt-4o-mini)
# LLM_MODEL=claude-sonnet-4-6

# API keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Real target chatbot (leave blank to use mock)
# TARGET_CHATBOT_URL=https://your-enterprise-chatbot-api/chat
# TARGET_CHATBOT_API_KEY=your_chatbot_key_here
